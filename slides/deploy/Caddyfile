# Caddy 2 configuration for the Replay 2026 Nexus workshop.
# Hosts everything behind a single domain via subpaths:
#   /                 - landing page (static, three buttons)
#   /slides           - Slidev dev server, reverse-proxied to localhost:3030
#   /slides/presenter - same, but locked behind HTTP basic auth
#   /export           - Slidev's built-in export UI (print-to-PDF / PNG)
#   /game             - static topology sandbox from the sibling code repo
#
# Before installing:
#   1. Replace `nexus.example.com` with your domain.
#   2. Replace the placeholder bcrypt hash on the `mason` line below
#      with the output of `caddy hash-password` on the VPS.
# Caddy auto-provisions Let's Encrypt certs on first HTTPS request.

nexus.example.com {
    encode gzip zstd

    log {
        output file /var/log/caddy/nexus-access.log {
            roll_size 10mb
            roll_keep 5
        }
        format console
    }

    # Game: single-file HTML from the sibling code repo. `handle_path`
    # strips the /game prefix; try_files falls back to index.html so
    # /game and /game/ both serve the sandbox.
    handle_path /game* {
        root * /opt/workshop-nexus-intro-code/game
        try_files {path} /index.html
        file_server
    }

    # Export route. Slidev ships a /export client page (browser
    # print-to-PDF + PNG capture UI). We rewrite /export to its
    # base-prefixed path and proxy through. No file on disk, no
    # headless browser, always current with the deck.
    @export path /export
    handle @export {
        rewrite * /slides/export
        reverse_proxy localhost:3030
    }

    # Slides presenter view: lock /slides/presenter behind basic auth so
    # only the driver can navigate the room. Attendees on /slides are
    # not prompted. Generate the hash with `caddy hash-password`.
    @presenter path /slides/presenter /slides/presenter/*
    handle @presenter {
        basicauth {
            mason REPLACE_WITH_BCRYPT_HASH_FROM_CADDY_HASH_PASSWORD
        }
        reverse_proxy localhost:3030
    }

    # Slides public view. Vite HMR and Slidev presenter-sync WebSockets
    # both ride this proxy; Caddy 2 transparently upgrades WSS.
    handle /slides* {
        reverse_proxy localhost:3030
    }

    # Slidev / Vite internal endpoints have two conventions on the dev
    # server: GET handlers honour --base (so the JS module URL is at
    # /slides/@server-reactive/nav), but the POST sync handlers from
    # vite-plugin-vue-server-ref are registered at the ROOT regardless
    # of --base (POST /@server-reactive/nav). Caddy has to split the
    # two: rewrite the GET, pass the POST through unchanged.
    #
    # Without this split, presenter -> audience navigation sync breaks:
    # the presenter posts to /@server-reactive/nav and a rewritten
    # /slides/@server-reactive/nav returns 404, so the broadcast that
    # tells /slides clients to advance never fires.
    @serverReactiveSync {
        method POST
        path /@server-reactive/*
    }
    handle @serverReactiveSync {
        reverse_proxy localhost:3030
    }

    # Slidev / Vite internal GET endpoints (e.g. /@server-reactive/*,
    # /@vite/*, /@id/*, /@fs/*) are emitted at the root path even when
    # Slidev runs with --base /slides/. The dev server only answers them
    # under the prefix, so rewrite the path before proxying. Without
    # this, presenter view mounts but the @server-reactive module never
    # loads.
    handle /@* {
        rewrite * /slides{uri}
        reverse_proxy localhost:3030
    }

    # Slidev's slide-info JSON API (/__slidev/slides/<n>.json) is the
    # canonical data source for the NoteEditable / NoteStatic components
    # in presenter mode. Slidev registers this at the root of its dev
    # server REGARDLESS of --base, so it must NOT be rewritten - just
    # proxied through. Without this, presenter notes never load.
    handle /__slidev/* {
        reverse_proxy localhost:3030
    }

    # Landing page at /. Anything that does not match above lands here.
    handle {
        root * /opt/workshop-nexus-intro-instruqt/slides/deploy/landing
        try_files {path} /index.html
        file_server
    }
}
