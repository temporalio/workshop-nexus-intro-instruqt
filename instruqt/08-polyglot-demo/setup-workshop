#!/bin/bash
set -euxo pipefail
source /root/.bashrc

pkill -f "payments.worker"     || true
pkill -f "compliance.worker"   || true
pkill -f "ComplianceWorkerApp" || true

# Sparse-stage: wipe all chapters and copy in only Ch 7 (the polyglot demo
# runs against the Ch 7 solution state on the Python side).
CHAPTER=07_lifecycle
rm -rf /root/workshop/exercises
mkdir -p /root/workshop/exercises
cp -r "/opt/workshop/exercises/$CHAPTER" "/root/workshop/exercises/$CHAPTER"
# Pre-apply the Ch 7 solution so attendees do not have to re-do the failure injections.
cp -r "/root/workshop/exercises/$CHAPTER/solution/." "/root/workshop/exercises/$CHAPTER/exercise/"

# Re-stage the Java polyglot tree from the baked-in source.
rm -rf /root/workshop/polyglot
cp -r /opt/workshop/polyglot /root/workshop/polyglot

# The image pre-bakes target/ via `mvn -DskipTests package` at build time.
# Rebuild on the fly if it is missing for any reason (cache miss, manual wipe).
if [ ! -d /root/workshop/polyglot/java-legacy/target ]; then
    mvn -q -f /root/workshop/polyglot/java-legacy/pom.xml -DskipTests package
fi

temporal operator nexus endpoint create \
    --name compliance-endpoint \
    --target-namespace compliance-namespace \
    --target-task-queue compliance-risk \
    --description-file /root/workshop/compliance-endpoint.md \
    --address 127.0.0.1:7233 || true
