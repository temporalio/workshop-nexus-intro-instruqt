#!/bin/bash
set -euxo pipefail
source /root/.bashrc

pkill -f "payments.worker"     || true
pkill -f "compliance.worker"   || true
pkill -f "ComplianceWorkerApp" || true
sleep 1

# Polyglot solve: stop Python compliance, start Java compliance, run a normal txn.
cd /root/workshop/polyglot/java-legacy
mvn -q exec:java &
JAVA_PID=$!
sleep 8

cd /root/workshop/exercises/07_lifecycle/exercise
uv run python -m payments.worker &
PAYMENTS_PID=$!
sleep 3

uv run python -m payments.starter

kill $PAYMENTS_PID 2>/dev/null || true
wait $PAYMENTS_PID 2>/dev/null || true
kill $JAVA_PID 2>/dev/null || true
pkill -f "ComplianceWorkerApp" || true
