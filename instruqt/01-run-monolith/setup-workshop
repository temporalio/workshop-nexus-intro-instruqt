#!/bin/bash
set -euxo pipefail
source /root/.bashrc

# Belt-and-braces: kill any workers a previous run left behind.
pkill -f "payments.worker"     || true
pkill -f "compliance.worker"   || true
pkill -f "ComplianceWorkerApp" || true

# Sparse-stage: wipe all chapters from /root/workshop/exercises and copy in
# only the current one. End-state matches the Tailscale workshop's
# sparse-checkout: just this chapter visible on disk under exercises/.
# Shared root files (.venv, pyproject.toml, uv.lock, compliance-endpoint.md)
# remain intact at /root/workshop/.
CHAPTER=01_run_monolith
rm -rf /root/workshop/exercises
mkdir -p /root/workshop/exercises
cp -r "/opt/workshop/exercises/$CHAPTER" "/root/workshop/exercises/$CHAPTER"
